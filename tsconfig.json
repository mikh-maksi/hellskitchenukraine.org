{
  "compilerOptions": {
    "sourceMap": true,
    "jsx": "react",
    "lib": ["dom", "es6", "esnext"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true
  },
  "exclude": ["node_modules", ".next", "build", "dist"]
}
